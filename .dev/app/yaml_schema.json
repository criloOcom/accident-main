{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "YAML Frontmatter — Accident de la Main",
  "description": "Schéma canonique pour les frontmatter YAML des fichiers .md du dépôt",
  "type": "object",
  "properties": {
    "emoji": { "type": "string", "description": "Emoji représentatif du document" },
    "title": { "type": "string", "description": "Titre court du document (obligatoire)" },
    "subtitle": { "type": "string", "description": "Sous-titre contextuel" },
    "objective": { "type": "string", "description": "Objectif du document (pourquoi ce document existe)" },
    "summary": { "type": "string", "description": "Résumé du contenu en 1-2 phrases" },
    "key_points": { "type": "array", "items": { "type": "string" }, "description": "Points clés structurés" },
    "recipient": { "type": "string", "description": "Destinataire nominal du document" },
    "jurisdiction": { "type": "string", "description": "Juridiction compétente" },
    "legal_basis": {
      "oneOf": [
        { "type": "string" },
        { "type": "array", "items": { "type": "string" } }
      ],
      "description": "Base légale / fondement juridique"
    },
    "description": { "type": "string", "description": "Description libre du document" },
    "type": { "type": "string", "description": "Type canonique du document" },
    "date": { "type": "string", "description": "Date YYYY-MM-DD ou FIXME" },
    "statut": { "type": "string", "description": "Statut du document" },
    "urgence": { "type": "string", "description": "Niveau d'urgence" },
    "urgency": { "type": "string", "enum": ["basse", "moyenne", "haute", "critique"], "description": "Urgence (anglais, recommandé)" },
    "tags": { "type": "array", "items": { "type": "string" }, "description": "Tags de catégorisation" },
    "auteur": { "type": "string", "description": "Auteur du document (token ou réel)" },
    "destinataire": { "type": "string", "description": "Destinataire du document" },
    "reel_path": { "type": "string", "description": "Chemin relatif vers la version réelle" },
    "calendar_event_id": { "type": "string", "description": "ID Google Calendar associé" },
    "jx": { "type": "string", "pattern": "^J±?[0-9]{1,2}$", "description": "Code J±XX" },
    "legiarti": { "type": "string", "pattern": "^LEGIARTI", "description": "ID Légifrance article" },
    "juritext": { "type": "string", "pattern": "^JURITEXT", "description": "ID Légifrance décision" }
  },
  "required": ["title", "type"],
  "allOf": [
    {
      "if": { "properties": { "type": { "enum": ["courrier", "assignation", "plainte", "attestation", "preuve", "rapport", "loi", "jurisprudence"] } } },
      "then": { "required": ["date"] }
    }
  ]
}
