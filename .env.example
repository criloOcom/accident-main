# ════════════════════════════════════════════════════════════════
# Configuration locale — accident-main
# ════════════════════════════════════════════════════════════════

# ── Vertex AI / Gemini (Google ADK) ──────────────────────────
GOOGLE_GENAI_USE_VERTEXAI=true
GOOGLE_CLOUD_PROJECT=crilo-prod-automation
GOOGLE_CLOUD_LOCATION=global

# Alternative : Gemini API Key (commenter les 3 lignes ci-dessus)
# GEMINI_API_KEY=your-api-key-here

# ── MCP Credentials ───────────────────────────────────────────
# Ces fichiers doivent être présents dans ~/.opencode/
# Ne JAMAIS les versionner dans Git.
#
#   gcp-oauth.keys.json       ← OAuth2 Google (Docs, Gmail, Drive)
#   gcp_souverain_token.json  ← OAuth2 Piste (Légifrance, Judilibre)

# ── Google Drive (Jules) ──────────────────────────────────────
# Ces vars sont utilisées par setup.sh pour créer .drive-token.json
# (Jules les supprime après le setup — le fichier persiste)
# Configurer dans Jules Settings (jules.google.com/settings)
#
# GOOGLE_DRIVE_CLIENT_ID=your-client-id
# GOOGLE_DRIVE_CLIENT_SECRET=your-client-secret
# GOOGLE_DRIVE_REFRESH_TOKEN=your-refresh-token
# GOOGLE_DRIVE_FOLDER_ID=16Qm2fEzojRQ3_yylsSwlkynbVv1L0SvB
#
# ── Piste (MCP Bridge) ────────────────────────────────────────
# JSON complet des credentials API Piste (via tools.py → get_secret)
# Utilisé par setup.sh pour créer .piste-credentials.json
#
# PISTE_CREDENTIALS={"piste":{...}}
